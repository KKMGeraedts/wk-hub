{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "vite",
  "buildCommand": "npm run build",
  "outputDirectory": "frontend/dist",
  "functions": {
    "api/index.py": {
      "includeFiles": "backend/*.json",
      "excludeFiles": "{frontend/**,node_modules/**,backend/__pycache__/**,**/*.pyc}"
    }
  },
  "crons": [
    {
      "path": "/api/cron/api-football-sync",
      "schedule": "0 8 * * *"
    },
    {
      "path": "/api/cron/api-football-squad-sync",
      "schedule": "30 8 * * *"
    }
  ],
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "/api/index.py"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
